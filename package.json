{
  "name": "confui",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Turn project configuration files into clear, safely editable desktop forms.",
  "author": "1Beyond1",
  "repository": "https://github.com/1Beyond1/confui",
  "engines": {
    "node": ">=20.19.0"
  },
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test && npm run build",
    "package": "npm run build && node scripts/package.mjs"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@types/ini": "^4.1.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.20.1",
    "electron": "^41.10.2",
    "electron-vite": "^5.0.0",
    "typescript": "^5.6.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "ini": "^6.0.0",
    "js-yaml": "^5.2.1",
    "jsonc-parser": "^3.3.1",
    "preact": "^10.29.7",
    "smol-toml": "^1.7.0"
  }
}
