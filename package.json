{
  "name": "confui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Auto-detect config files in any project and edit them through a generated UI form.",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "package": "electron-vite build && npx electron-packager . Confui --platform=win32 --arch=x64 --out=release --overwrite --ignore=\"\\\\.git|node_modules\\\\.cache|\\\\.playwright-cli|release|src|server|shared|electron\\\\.vite\\\\.config\\\\.ts|PROJECT_SPEC|kimi\" --prune=true",
    "package:win": "electron-vite build && electron-builder --win"
  },
  "devDependencies": {
    "@types/ini": "^4.1.1",
    "@types/js-yaml": "^4.0.9",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@preact/preset-vite": "^2.10.5",
    "ini": "^6.0.0",
    "js-yaml": "^5.2.1",
    "jsonc-parser": "^3.3.1",
    "preact": "^10.29.7",
    "properties": "^1.2.1",
    "smol-toml": "^1.7.0",
    "vite": "^5.4.21"
  },
  "build": {
    "productName": "Confui",
    "appId": "com.confui.app",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Confui-Setup-.exe"
    }
  }
}
